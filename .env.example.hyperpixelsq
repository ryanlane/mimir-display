# ==============================================
# .env Example – HyperPixel 4.0 Square (fb0)
# ==============================================

# Backend selection
DISPLAY_BACKEND=hyperpixelsq

# Platform
PLATFORM_URL=http://localhost:5000
AUTH_TOKEN=

# Identity
DISPLAY_NAME=HyperPixel Display
DISPLAY_LOCATION=West Gallery
DISPLAY_TAGS=hyperpixelsq,pi
CLIENT_VERSION=1.0.0

# Behavior / Timing
POLL_INTERVAL_SECONDS=30
RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=5
CACHE_TIMEOUT_SECONDS=300
DEFAULT_CONTENT_PATH=./images/startup.png

# Distribution
USE_REDIS_DISTRIBUTION=true
ASSIGNMENT_TTL_SECONDS=300

# Webhook
WEBHOOK_ENABLED=true
WEBHOOK_PORT=8080

# MQTT
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=
MQTT_KEEPALIVE=60
MQTT_HEARTBEAT_INTERVAL=30
MQTT_QOS=1
MQTT_RETAIN=false

# Orientation
# Values: landscape | portrait_left | portrait_right
DISPLAY_ORIENTATION=landscape

# Optional: resolution override (landscape native order)
# DISPLAY_NATIVE_RESOLUTION=720x720

# HyperPixel framebuffer tuning
# Endianness for RGB565 pixel word storage: little | big
# Default follows host endianness (Pi = little)
# HYPERPIXEL_RGB565_ENDIAN=little

# Channel order before pack: rgb | bgr
# HYPERPIXEL_RGB565_CHANNEL=rgb

# Force bits-per-pixel (16, 24, 32). Otherwise detected via sysfs.
# HYPERPIXEL_FORCE_BPP=16

# For 32bpp modes: byte sequence (low address -> high) using {R,G,B,A,X}
# Typical memory order for XRGB8888 (little-endian) is BGRX
# HYPERPIXEL_8888_SEQ=BGRX

# Log first N bytes of first fb write (debug byte order)
# HYPERPIXEL_LOG_FIRST_BYTES=64

# Paths & Mode
DATA_DIR=./runstate
# ENVIRONMENT=development
