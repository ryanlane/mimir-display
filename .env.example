# Display backend: inky | hyperpixelsq | auto
DISPLAY_BACKEND=auto

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# --- Platform ---
PLATFORM_URL=http://localhost:5000
AUTH_TOKEN=

# --- Display identity ---
DISPLAY_ID=
DISPLAY_NAME=Display Name
DISPLAY_LOCATION=West Gallery
DISPLAY_TAGS=inky,pi-zero
CLIENT_VERSION=1.0.0
# HOSTNAME is automatically detected, but can be overridden here
# HOSTNAME=colorframe05

# --- Behavior ---
POLL_INTERVAL_SECONDS=30
RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=5
CACHE_TIMEOUT_SECONDS=300
DEFAULT_CONTENT_PATH=./example_default.png

# --- Redis Distribution ---
USE_REDIS_DISTRIBUTION=true
ASSIGNMENT_TTL_SECONDS=300

# --- mDNS Discovery ---
# mDNS is automatically enabled when display is registered
# No additional configuration needed

# --- Webhook Server (for manual updates) ---
WEBHOOK_ENABLED=true
WEBHOOK_PORT=8080

# --- MQTT Configuration ---
# Hostname or IP of the MQTT broker.
# If you rely on mDNS/Avahi, remember to include the .local suffix, e.g. oak.local
# MQTT_BROKER_HOST=oak.local
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=
MQTT_KEEPALIVE=60
MQTT_HEARTBEAT_INTERVAL=30
MQTT_QOS=1
MQTT_RETAIN=false

# --- Paths & mode ---
DATA_DIR=./runstate
LOG_LEVEL=INFO
# ENVIRONMENT=development  # uncomment for dev (eframe_inky uses this to fake output)

# --- Orientation ---
# Physical mounting orientation of the display. Determines reported resolution and image rotation.
# Accepted values:
#   landscape       - (default) 800x480 (no rotation)
#   portrait_left   - device rotated 90° counter-clockwise (top is original left edge). Images rotated 90° clockwise.
#   portrait_right  - device rotated 90° clockwise (top is original right edge). Images rotated 90° counter-clockwise.
#   square         - for square displays (e.g. 600x600). No rotation.
# NOTE: When portrait_* is selected, the client reports swapped resolution (480x800) to the platform.
DISPLAY_ORIENTATION=landscape

# --- Resolution Override (optional) ---
# Use when hardware auto-detection fails or for new panel sizes.
# Format: WIDTHxHEIGHT (landscape native ordering). Example: 1600x1200
# When set, this overrides detected hardware resolution.
# DISPLAY_NATIVE_RESOLUTION=1600x1200