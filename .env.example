# ==============================
# Mimir Display Client .env Example
# ==============================

# Display backend selection: inky | hyperpixelsq | auto
# 'auto' will inspect /dev/fb0 and sysfs to decide (HyperPixel if 720x720 RGB565; otherwise Inky; fallback simulation).
DISPLAY_BACKEND=auto

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# --- Platform ---
PLATFORM_URL=http://localhost:5000
AUTH_TOKEN=

# --- Display identity ---
DISPLAY_ID=
DISPLAY_NAME=Display Name
DISPLAY_LOCATION=West Gallery
DISPLAY_TAGS=inky,pi-zero
CLIENT_VERSION=1.0.0
# HOSTNAME is automatically detected, but can be overridden here
# HOSTNAME=colorframe05

# --- Behavior / Timing ---
POLL_INTERVAL_SECONDS=30          # (reserved/future) Poll fallback
RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=5
CACHE_TIMEOUT_SECONDS=300
DEFAULT_CONTENT_PATH=./example_default.png

# Startup visuals
STARTUP_LOGO_PATH=                # Optional override path to logo (otherwise built-in startup.png)
STARTUP_TEST_PATTERN=0            # If 1 (and hyperpixelsq), draw diagnostic gradient before logo

# --- Redis Distribution ---
USE_REDIS_DISTRIBUTION=true
ASSIGNMENT_TTL_SECONDS=300

# --- mDNS Discovery ---
# mDNS is automatically enabled when display is registered
# No additional configuration needed

# --- Webhook Server (for manual updates) ---
WEBHOOK_ENABLED=true
WEBHOOK_PORT=8080

# --- MQTT Configuration ---
# Hostname or IP of the MQTT broker.
# If you rely on mDNS/Avahi, remember to include the .local suffix, e.g. oak.local
# MQTT_BROKER_HOST=oak.local
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=
MQTT_KEEPALIVE=60
MQTT_HEARTBEAT_INTERVAL=30
MQTT_QOS=1
MQTT_RETAIN=false
MQTT_HEARTBEAT_INTERVAL=30

# --- Paths & Mode ---
DATA_DIR=./runstate                # State + cache root (contains cache/, logs/, etc.)
# ENVIRONMENT=development          # Uncomment for development mode behaviors

# --- Orientation ---
# Physical mounting orientation of the display. Determines reported resolution and image rotation.
# Accepted values:
#   landscape       - default; no rotation
#   portrait_left   - physical panel rotated CCW 90° (content rotated +90°)
#   portrait_right  - physical panel rotated CW 90° (content rotated +270°)
# NOTE: When portrait_* is selected, reported logical resolution is swapped.
DISPLAY_ORIENTATION=landscape

# --- Resolution Override (optional) ---
# Provide when auto-detection fails or for testing new panels.
# Format: WIDTHxHEIGHT (native landscape ordering). Example: 1600x1200
# DISPLAY_NATIVE_RESOLUTION=1600x1200

# --- HyperPixel Framebuffer Tuning (runtime overrides) ---
# Endianness for RGB565 pixel word storage: little | big (defaults to host endianness if unset)
# HYPERPIXEL_RGB565_ENDIAN=little
# Channel order mapping before pack: rgb | bgr
# HYPERPIXEL_RGB565_CHANNEL=rgb
# Force bits-per-pixel interpretation (16, 24, or 32). Otherwise detected from sysfs.
# HYPERPIXEL_FORCE_BPP=16
# For 32bpp modes: byte sequence (low address -> high) using characters in {R,G,B,A,X}
# HYPERPIXEL_8888_SEQ=BGRX
# Log the first N bytes of the first framebuffer write (hex) for debugging color ordering.
# HYPERPIXEL_LOG_FIRST_BYTES=64

# --- Advanced / Diagnostics ---
# STARTUP_LOGO_PATH already listed above; repeated here for clarity.
# Set to force test gradient: STARTUP_TEST_PATTERN=1

# --- Update Script Note ---
# Use scripts/update_display.sh to sync changes and restart the service after edits.