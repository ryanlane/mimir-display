# =====================================
# Mimir Display Client – .env (Generic)
# =====================================

# Display backend selection: inky | hyperpixelsq | rgbmatrix | hdmi | auto
DISPLAY_BACKEND=auto  # auto: detect fb (HyperPixel) or fallback to inky

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# --- Platform ---
PLATFORM_URL=http://localhost:5000
AUTH_TOKEN=

# --- Display identity ---
DISPLAY_ID=
DISPLAY_NAME=Display Name
DISPLAY_LOCATION=West Gallery
DISPLAY_TAGS=inky,pi-zero
CLIENT_VERSION=1.0.0
# HOSTNAME is automatically detected, but can be overridden here
# HOSTNAME=colorframe05

# --- Behavior / Timing ---
POLL_INTERVAL_SECONDS=30
RETRY_ATTEMPTS=3
RETRY_DELAY_SECONDS=5
CACHE_TIMEOUT_SECONDS=300
DEFAULT_CONTENT_PATH=./images/startup.png

# Startup visuals
STARTUP_LOGO_PATH=                # Optional override path to logo (otherwise built-in startup.png)
STARTUP_TEST_PATTERN=0            # If 1 (and hyperpixelsq), draw diagnostic gradient before logo

# --- Distribution ---
USE_REDIS_DISTRIBUTION=true
ASSIGNMENT_TTL_SECONDS=300

# --- mDNS Discovery ---
# mDNS is automatically enabled when display is registered
# No additional configuration needed

# --- Webhook Server (for manual updates) ---
WEBHOOK_ENABLED=true
WEBHOOK_PORT=8080

# --- MQTT Configuration ---
# If you rely on mDNS/Avahi, include the .local suffix (e.g., broker.local)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_CLIENT_ID=
MQTT_KEEPALIVE=60
MQTT_HEARTBEAT_INTERVAL=30
MQTT_QOS=1
MQTT_RETAIN=false

# Advanced MQTT watchdog/reconnect tunables (optional)
# MQTT_WATCHDOG_IDLE_WARN=45
# MQTT_WATCHDOG_IDLE_ERROR=120
# MQTT_WATCHDOG_INTERVAL=15
# MQTT_RECONNECT_BASE_DELAY=2
# MQTT_RECONNECT_MAX_DELAY=60
# MQTT_RECONNECT_JITTER=0.25
# MQTT_RECONNECT_LOG_EVERY=5

# --- Paths & Mode ---
DATA_DIR=./runstate  # State + cache root (contains cache/, logs/, etc.)
# ENVIRONMENT=development

# --- Orientation ---
# Physical mounting orientation of the display. Determines reported logical resolution and pre-display rotation.
# Accepted values:
#   landscape       - no rotation
#   portrait_left   - panel physically CCW 90° (content rotated +90°)
#   portrait_right  - panel physically CW 90°  (content rotated +270°)
# Auto-detection (when variable unset):
#   * If native height > native width  -> inferred portrait_right
#   * If native width == native height -> landscape (square treated as landscape space)
#   * Else                             -> landscape
# NOTE: For portrait_* orientations, reported logical resolution swaps width/height.
DISPLAY_ORIENTATION=landscape

# --- Resolution Override (optional) ---
# Provide when auto-detection fails or for testing new panels.
# Format: WIDTHxHEIGHT (native landscape ordering). Example: 1600x1200
# DISPLAY_NATIVE_RESOLUTION=1600x1200

# Backend-specific settings live in separate samples for clarity:
#   .env.example.hyperpixelsq  – HyperPixel framebuffer overrides
#   .env.example.rgbmatrix     – RGB LED Matrix configuration

# --- Advanced / Diagnostics ---
# STARTUP_LOGO_PATH already listed above; repeated here for clarity.
# Set to force test gradient: STARTUP_TEST_PATTERN=1

# --- Update Script Note ---
# Use scripts/update_display.sh to sync changes and restart the service after edits.